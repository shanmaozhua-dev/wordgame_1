[sub_resource type="Shader" id=2]
code = "shader_type canvas_item;
uniform float t :hint_range(0,1) = 0.;

float box(vec2 lt, vec2 rb, vec2 uv) {
	return step(lt,uv).x * step(lt,uv).y * step(uv,rb).x * step(uv,rb).y;
}

float px(vec2 pos, float size, vec2 uv) {
	return box(pos-size/2., pos+size/2., uv);
}

void fragment() {
	float a = box(vec2(.25), vec2(.75), UV) * (1.-t) * .15;
	
	float t1 = smoothstep(0.,.85,t);
	float t2 = smoothstep(.05,.9,t);
	float t3 = smoothstep(.075,.8,t);
	float t4 = smoothstep(.1,1.,t);
	
	vec2 p1 = vec2(.375-t1*.1, .45-.15*pow(t1, 4.));
	vec2 p2 = vec2(.575+t2*.05, .4-.2*pow(t2, 3.));
	vec2 p3 = vec2(.475-t3*.025, .625-.1*pow(t3, 3.5));
	vec2 p4 = vec2(.625+t4*.075, .725-.2*pow(t4, 4.));
	
	a += px(p1, .035 * smoothstep(0.,.75,t1), UV) * smoothstep(1.,.45,t1);
	a += px(p2, .025 * smoothstep(.25,.85,t2), UV) * smoothstep(1.,.35,t2);
	a += px(p3, .02 * smoothstep(.15,.65,t3), UV) * smoothstep(1.,.25,t3);
	a += px(p4, .025 * smoothstep(.1,.725,t4), UV) * smoothstep(1.,.35,t4);
	
	COLOR = vec4(.8,.8,.8,1.);
	COLOR.a = a;
	COLOR *= step(.001, t);
}"

