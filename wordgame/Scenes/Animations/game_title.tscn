[sub_resource type="Shader" id=5]
code = "shader_type canvas_item;

const vec2 size = vec2(96.0, 54.0);

void fragment() {
	vec2 uv = UV;
	uv *= size;
	vec2 id = floor(uv);
	
	COLOR.rgb = vec3(1.0);
	COLOR.a = texture(TEXTURE,UV).r;
	COLOR.a *= step(id.x-id.y*2.75, -17.0);
}"

[sub_resource type="ShaderMaterial" id=6]
shader = SubResource( 5 )

[sub_resource type="Shader" id=7]
code = "shader_type canvas_item;

uniform float s :hint_range(0, 1) = 0;
uniform float t :hint_range(0, 1) = 0;
const vec2 size = vec2(96.0, 54.0);

void fragment() {
	vec2 uv = UV;
	uv *= size;
	vec2 id = floor(uv);
	
	float c = smoothstep((1.0-t)*(size.x+2.0*size.y), (1.0-t)*(size.x+2.0*size.y)+5.0, id.x+5.0*t*id.y);
	c *= smoothstep((1.0-t)*(size.x+2.0*size.y)+25.0, (1.0-t)*(size.x+2.0*size.y)+5.0, id.x+4.5*t*id.y);
	float start = smoothstep((1.0-s)*(size.x+2.0*size.y), (1.0-s)*(size.x+2.0*size.y)+5.0, id.x+5.0*s*id.y);
	
	COLOR = texture(TEXTURE, UV);
	COLOR.a -= c;
	COLOR.a *= start;
	COLOR.a = clamp(COLOR.a, 0.0, 1.0);
}"

