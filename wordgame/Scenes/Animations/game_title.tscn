[sub_resource type="Shader" id=16]
code = "shader_type canvas_item;

const vec2 size = vec2(96.0, 54.0);

void fragment() {
	vec2 uv = UV;
	uv *= size;
	vec2 id = floor(uv);
	
	COLOR.rgb = vec3(1.0);
	COLOR.a = texture(TEXTURE,UV).r;
	COLOR.a *= 1.0 - step(id.x-id.y*2.75, -20.5);
}"

[sub_resource type="ShaderMaterial" id=17]
shader = SubResource( 16 )

[sub_resource type="Shader" id=18]
code = "shader_type canvas_item;

uniform float start :hint_range(0,1) = 0;
uniform float end :hint_range(0,1) = 0;

const vec2 size = vec2(96.,54.);

void fragment() {
	vec2 uv = UV;
	uv.y = 1.-uv.y;
	uv *= size;
	vec2 id = floor(uv);
	vec2 uv_by_id = id/size;
	
	float s = clamp(.18,.93,start);
	float e = clamp(.18,.93,end);
	
	COLOR.a = 1.-step(id.x-id.y*2.75, -23.);
	COLOR.a *= step(id.x-id.y*2.75, -19.);
	COLOR.a *= step(uv_by_id.x, s);
	COLOR.a *= step(e, uv_by_id.x);
}"

