[sub_resource type="GDScript" id=1]
script/source = "extends Node2D


func standby():
	var tw = create_tween()
	tw.set_parallel(true)
	tw.tween_property(self, \"position:y\", position.y-120, 2).from(position.y).set_trans(Tween.TRANS_SINE).set_ease(Tween.EASE_IN_OUT)
	await tw.finished
"

