[sub_resource type="Shader" id=1]
code = "shader_type canvas_item;


uniform float val;
uniform float speed;
uniform float tilt;
uniform int split;

uniform float p_size;
uniform float p_lifetime;

vec4 pix(float size, float lifetime, float u_t, vec2 u_uv) {
	float t_id = floor(u_t/lifetime);
	float t_gv = fract(u_t/lifetime);
	
	vec2 pos = vec2(0.25 * sin(t_id * 22.5696578) + 0.5, 0.25 * sin(t_id * 83.465753) + 0.5);
	size = size * sin(t_gv * PI);
	
	float grey = 0.6 * step(pos.x-size/2., u_uv.x) * step(u_uv.x, pos.x+size/2.) * step(pos.y-size/2., u_uv.y) * step(u_uv.y, pos.y+size/2.);
	
	return vec4(vec3(grey), 0.);
}

void fragment() {
	vec2 uv = UV;
	vec2 gv = fract(uv);
	
	float yv = uv.y * float(split);
	float level = floor(yv);
	float dir = 2.0 * (mod(level, 2.0) - 0.5);
	
	gv.x += dir * val * sin(gv.y * tilt + TIME * speed);
	COLOR = abs(texture(TEXTURE, gv) - pix(p_size, p_lifetime, TIME, UV) - pix(p_size, p_lifetime, TIME+8.5*p_lifetime, UV) - pix(p_size, p_lifetime, TIME+10.2*p_lifetime, UV));
}"

