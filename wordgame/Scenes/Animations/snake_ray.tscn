[sub_resource type="Shader" id=4]
code = "shader_type canvas_item;


uniform float t = .99;
uniform float p1_seed = 404.;
uniform float p2_seed = 426.;
uniform float p3_seed = 420.;
uniform float p4_seed = 1198.;

float stonelight(float l_deep, float l_wide, float u_time, vec2 u_uv) {
	u_time = sin(fract(u_time) * PI);
	
	float wide = 1. - abs(u_uv.x - 0.5) * 2. / l_wide;
	wide = clamp(wide, 0., 1.);
	
	float deep = 1. - smoothstep(.25, .25 + l_deep, u_uv.y);
	deep = clamp(deep, 0., 1.) * step(.25, u_uv.y);
	
	return u_time * wide * deep;
}

float pix(float seed, float u_time, vec2 u_uv) {
	u_time = fract(u_time);
	
	float size = .2 - u_time * .2;
	size = clamp(size, .0, .1);
	
	vec2 pos = vec2(.5, .25);
	float ang = PI/2. + PI/2. * sin(seed*258.478932679);
	float dist = 0.5 * abs(sin(seed*578.742536));
	pos = pos + sqrt(u_time) * vec2(dist * cos(ang), dist * sin(ang));
	
	float alpha = step(u_uv, pos+vec2(size/2.)).x * step(u_uv, pos+vec2(size/2.)).y * step(pos-vec2(size/2.), u_uv).x * step(pos-vec2(size/2.), u_uv).y;
	return alpha;
}

void fragment() {
	
	COLOR.a = stonelight(.25, .75, t, UV);
	COLOR.a += pix(p1_seed, t, UV);
	COLOR.a += pix(p2_seed, t, UV);
	COLOR.a += pix(p3_seed, t, UV);
	COLOR.a += pix(p4_seed, t, UV);
	COLOR.a = clamp(COLOR.a, 0., 1.);
}"

