[sub_resource type="Shader" id=17]
code = "shader_type canvas_item;

uniform vec2 pos;
uniform float t :hint_range(0., 1.) = 0.;
uniform int subdivide :hint_range(0, 60) = 20;
uniform int level :hint_range(0, 10) = 5;


float rand(vec2 co){
    return fract(sin(dot(co.xy ,vec2(12.9898,78.233))) * 43758.5453);
}

float rail(vec2 uv) {
	float col = 0.;
	float my_level = floor((1.-uv.y) * float(level));
	col += my_level / float(level);
	col += uv.x / float(level) * float(int(my_level)%2);
	col += (1.-uv.x) / float(level) * float(int(my_level+1.)%2);
	return col;
}

vec2 rotateUV(float rotation, vec2 uv) {
	float sine = sin(rotation);
	float cosine = cos(rotation);

	uv -= .5;
	uv = vec2(
		uv.x * cosine - uv.y * sine, 
		uv.x * sine + uv.y * cosine
		);
	uv += .5;

	return uv;
}

void fragment() {
	vec2 uv = UV;
	uv *= float(subdivide);
	vec2 uv_by_id = floor(uv)/float(subdivide);
	uv_by_id = (uv_by_id-.5)*.7+.5;
	
	float r = (rand(pos) - .5) * PI * .5;
	float col = rail(rotateUV(r, uv_by_id));
	col = clamp(col, .001, .999);
	col = step(col, t);
	
	COLOR = texture(TEXTURE, UV);
	COLOR.a *= col;
}"

