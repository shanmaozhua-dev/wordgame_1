[sub_resource type="Shader" id=19]
code = "shader_type canvas_item;
uniform bool isIce;
uniform float t :hint_range(0., 1.) = 0.;
uniform vec2 size;
uniform int complexity = 10;
uniform int sub = 13;
uniform int OCTAVES = 6;
render_mode unshaded, blend_mul;

float rand(vec2 st) {
    return fract(sin(dot(st.xy,vec2(12.9898,78.233)))*43758.5453123);
}

float noise (in vec2 st) {
    vec2 i = floor(st);
    vec2 f = fract(st);

    // Four corners in 2D of a tile
    float a = rand(i);
    float b = rand(i + vec2(1.0, 0.0));
    float c = rand(i + vec2(0.0, 1.0));
    float d = rand(i + vec2(1.0, 1.0));

    vec2 u = f * f * (3.0 - 2.0 * f);

    return mix(a, b, u.x) +
            (c - a)* u.y * (1.0 - u.x) +
            (d - b) * u.x * u.y;
}

float fbm (in vec2 st) {
    // Initial values
    float value = 0.0;
    float amplitude = .5;
    float frequency = 0.;
    //
    // Loop of octaves
    for (int i = 0; i < OCTAVES; i++) {
        value += amplitude * noise(st);
        st *= 2.;
        amplitude *= .5;
    }
    return value * (float(OCTAVES)+1.) / float(OCTAVES);
}

void fragment() {
	vec2 uv = UV+.1+size;
	uv *= float(complexity);
	float com_by_sub = float(sub)/float(complexity);
	vec2 id = floor(uv*com_by_sub)/com_by_sub;
	
	float t1 = clamp(t*1.2, 0., 1.);
	float t2 = clamp(t*1.2-.2, 0., 1.);
	
	vec4 iced = vec4(vec3(step(fbm(id),t1)),1.) * vec4(vec3(.5),1.) + vec4(vec3(step(fbm(id),t2)), 0.)*vec4(-1.,1.,1.,0.);
	iced = clamp(iced, 0., 1.);
	
	vec4 stoned = vec4(vec3(step(fbm(id),t1)),1.) * vec4(vec3(.15),1.) + vec4(vec3(step(fbm(id),t2)), 0.)*vec4(.15,.15,.15,0.);
	stoned = clamp(stoned, 0., 1.);
	
	COLOR.rgb = float(isIce) * (iced.rgb * texture(TEXTURE,UV).rgb + texture(TEXTURE,UV).rgb * (1.-step(fbm(id),t1)));
	COLOR.rgb += (1.-float(isIce)) * (stoned.rgb * texture(TEXTURE,UV).rgb + texture(TEXTURE,UV).rgb * (1.-step(fbm(id),t1)));
}"

