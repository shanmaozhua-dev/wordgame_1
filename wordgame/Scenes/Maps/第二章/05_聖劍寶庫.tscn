[sub_resource type="GDScript" id=2]
script/source = "extends Node2D

var _compat_tween

func _input(ev):
	if Input.is_action_just_pressed(\"ui_translate\") && Global.settings.has_ts_mode:
		if !Global.get_game_switch(\"禁用簡繁轉換中\"):
			await get_tree().process_frame
			$zh.visible = !Global.is_simplified
			$cn.visible = Global.is_simplified

func _ready():
	$zh.visible = !Global.is_simplified
	$cn.visible = Global.is_simplified

var now_index = 1
func blur():
	visible = true
	var tween = create_tween()
	tween.set_parallel(true)
	tween.tween_method(Callable(self, \"on_blur_tweening\"), 1, 10, 20).set_trans(Tween.TRANS_LINEAR).set_ease(Tween.EASE_IN_OUT)
func unblur():
	var tween = create_tween()
	tween.set_parallel(true)
	if is_instance_valid(tween):
		tween.kill()
	tween = create_tween()
	tween.set_parallel(true)
	tween.tween_method(Callable(self, \"on_blur_tweening\"), now_index, 1, 2).set_trans(Tween.TRANS_LINEAR).set_ease(Tween.EASE_IN_OUT)
	await tween.finished
	visible = false

func on_blur_tweening(v):
	if now_index == floor(v): return
	now_index = floor(v)
	var num = str(now_index)
	if num.length()<2: num = \"0\"+num
	$zh.texture = load(\"res://Sprites/ch2_blur/ch2_blur_\"+num+\".png\")
	$cn.texture = load(\"res://Sprites/ch2_blur/ch2_blur_s_\"+num+\".png\")
"

