[node name="劍" parent="MainMap" instance=ExtResource( 5 )]
position = Vector2( 6120, 1500 )
z_index = 12
script = SubResource( 15 )
now_pos = Vector2( 102, 25 )
text = "劍"
loop_sprite_animation = {
"frame_count": 0,
"keyframes": "",
"path": "",
"time": 0.0
}
exist_condition = "s:ch2_劍出現==true"
is_high_priority = true
commands = "@[set_switch] [\"ch2_找到劍了\", true]

@[clear_typed] \"room4\"
@[wait] 30

@[type] {
	\"texts\": \"寶物堆中，||一支劍柄閃耀著與眾不同的光澤，\", 
	\"pos\": [70,32],
	\"tags\": [\"room4\"]
}

@[set_switch] [\"ch2_遮住寶藏\", true]

@[wait] 30

## 以下刪除新寶藏閃光
@[call_method] {
	\"target\": \"Node/MainMap/寶藏閃光\", 
	\"target_type\": \"path\",
	\"method\": \"queue_free\",
	\"arg_array\": []
}
## 以上刪除新寶藏閃光

@[play_se] {
	\"path\": \"res://Sounds/se/sword_draw_out_1.wav\", 
	\"db\": 0, 
	\"pan\": 0
}

@[wait] 30 ##frame

@[type] {
	\"texts\": \"我連忙伸手將它抽了出來，||轉頭看向詩人。\", 
	\"pos\": [70,33],
	\"tags\": [\"room4\"]
}

@[clear_typed] \"room4\"
@[wait] 30

@[type] {
	\"texts\": \"詩人露出一個欣慰的微笑。\", 
	\"pos\": [70,32],
	\"tags\": [\"room4\"]
}

@[wait] 30

@[move_route] {\"target\":\"player\", \"wait\":true}
	@[set_z_index] 13
@[end_move_route]

@[play_se] {
	\"path\": \"res://Sounds/se/第二章 音效/SE_2_25_sword_return.wav\", 
	\"db\": 0, 
	\"pan\": 0
}

@[wait] 30 ##frame

@[move_route] {\"target\":\"self\", \"wait\":true}
	@[set_through] true
	@[move_toward_player]
	@[set_through] false
@[end_move_route]

@[clear_typed] \"room4\"
@[wait] 30

@[type] {
	\"texts\": \"我感受到前所未有的能量在掌心流轉，&||
地面及岩壁震動，||耳邊傳來一串謎樣的響聲⋯⋯\", 
	\"pos\": [70,32],
	\"tags\": [\"room4\"],
    \"is_dialog_end\": true
}

@[set_switch] [\"ch2_劍出現\", false]
@[set_switch] [\"ch2_開始播聖劍動畫\", true]"

