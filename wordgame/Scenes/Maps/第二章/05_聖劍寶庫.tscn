@[wait] 30

@[type] {
	\"texts\": \"低頭一看，||等待在腳底下的，||是岩窟的無底深淵，\", 
	\"pos\": [70,24],
	\"tags\": [\"room4\"],
	\"need_accept\": false,
}

@[play_se] {
	\"path\": \"res://Sounds/se/第二章 音效/SE_2_27_rock_break.wav\", 
	\"db\": 0, 
	\"pan\": 0
}

@[crash_event] {\"target\": \"底\"}
@[wait] 60 ##frame

@[type] {
	\"texts\": \"以及迎面而來的未來劇本。\", 
	\"pos\": [70,25],
	\"tags\": [\"room4\"],
    \"is_dialog_end\": true
}

@[set_switch] [\"ch2_開始往下墜落句子出現\", true]

@[fade_out_bgm] 3.0

@[wait] 60

@[set_camera_follow_player] false

@[tween_parameter] {
	\"parameter\": \"position:y\", 
	\"add\": 2000, 
	\"time_sec\": 5, 
	\"transition_type\": \"TRANS_SINE\",
	\"ease_type\": \"EASE_IN\",
	\"target\": \"Node/MainMap/Player/Camera3D\",
	\"target_type\": \"path\",
	\"wait\": false
}

@[tween_parameter] {
	\"parameter\": \"position:y\", 
	\"add\": 3000,
	\"time_sec\": 5, 
	\"transition_type\": \"TRANS_SINE\",
	\"ease_type\": \"EASE_IN\",
	\"target\": \"Node/MainMap/Player\",
	\"target_type\": \"path\",
	\"wait\": false
}



@[wait] 180
@[fade_screen] \"#ff000000\"

@[stop_bgm]

@[map_transport] {
	\"map\": \"第二章/06_墜落\", 
	\"need_to_save_map_status\": false, 
	\"transition_type\": \"fade\", ##fade/whirl(漩渦)/none
	\"opacity\": 1
}"

