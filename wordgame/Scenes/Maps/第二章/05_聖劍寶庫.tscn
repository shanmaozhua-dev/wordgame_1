script/source = "extends Node

var _compat_tween


# Declare member variables here. Examples:
# var a = 2
# var b = \"text\"


# Called when the node enters the scene tree for the first time.
func _ready():
	if Global.get_game_switch(\"ch2_燈不亮了\") && !Global.get_game_switch(\"ch2_燈亮了\"):
		$\"../MainMap/黑幕/AnimationPlayer\".play(\"dark\")
	if Global.get_game_switch(\"ch2_沒空氣了\") && !Global.get_game_switch(\"ch2_有空氣了\"):
		$\"../MainMap/模糊\".blur()
		
	if Global.get_game_switch(\"ch2_開始挖寶藏\") && !Global.get_game_switch(\"ch2_開始播聖劍動畫\"):
#		$\"../MainMap/寶藏閃光/光\".play(\"loop\")
		$\"../MainMap/寶藏閃光/Sprite2D\".material.set_shader_parameter(\"t\", 1)
	if Global.get_game_switch(\"ch2_機會出現\")  && !Global.get_game_switch(\"ch2_開始播聖劍動畫\"):
		$\"../MainMap/機會\".opacity = 0
		$\"../MainMap/機會2\".opacity = 0
		$\"../MainMap/機會3\".opacity = 0
		$\"../MainMap/機會4\".opacity = 0
		$\"../MainMap/機會5\".opacity = 0
		$\"../機會出現動畫\".play(\"start\")
	
	
#	@[call_method] {
#	\"target\": \"Node/機會出現動畫\", 
#	\"target_type\": \"path\",
#	\"method\": \"play\",
#	\"arg_array\": [\"start\"]
#}
	pass # Replace with function body.


# Called every frame. 'delta' is the elapsed time since the previous frame.
#func _process(delta):
#	pass
"

