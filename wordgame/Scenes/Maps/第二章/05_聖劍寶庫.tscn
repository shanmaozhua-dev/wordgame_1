[sub_resource type="GDScript" id=15]
script/source = "@tool
extends \"res://Scripts/Event.gd\"

func _ready():
	if Engine.is_editor_hint():
		return

# override
func refresh():
	super.refresh()
	
	if is_exist_condition_valid():
		print(\"劍出現\")
		transport_to(get_rand_pos())
		var r = \"ABCDEF\"[randi()%6]
		Sound.play_se_with_position(\"res://Sounds/se/第二章 音效/SE_2_21_sword_crash_\"+r+\".wav\", self)
		countdown_vanish()
		
func get_rand_pos():
	var a = [
		\"00000000000000110000000000\",
		\"00000000000001111000000000\",
		\"00000011000000000000110000\",
		\"00000111100000000001111000\",
		\"00000000000000000000000000\",
		\"00000000000011100000000000\",
		\"00001100000111110000000000\",
		\"01110010000000000000001110\",
		\"11111111000000000000111111\"
	]
	var st = Vector2(67,21)
	
	var poss = []
	for y in range(a.size()):
		for x in range(a[y].length()):
			if a[y][x] == \"1\":
				var p = st + Vector2(x,y)
				poss.append(p)
#				Global.game_map.type(\"嗯\", p)
	poss.shuffle()
	
	return poss[0]
	
func countdown_vanish():
#	var count = Global.get_game_variable(\"ch2_調查寶藏次數\") - 6
#	var stay_time = min(10, 5+int(count))
	var stay_time = 5
	await get_tree().create_timer(stay_time).timeout
	if !Global.get_game_switch(\"ch2_找到劍了\"):
		var r = \"AB\"[randi()%2]
		Sound.play_se_with_position(\"res://Sounds/se/第二章 音效/SE_2_22_sword_vanish_\"+r+\".wav\", self)
		Global.set_game_switch(\"ch2_劍出現\", false)
		print(\"劍消失\")
"

[sub_resource type="Shader" id=16]
code = "shader_type canvas_item;
//render_mode blend_add;

uniform float pixels : hint_range(1, 60) = 30.0;

void fragment() {
	vec2 pixel_uv = UV;
	pixel_uv -= mod(pixel_uv, vec2(1.0/pixels, 1.0/pixels));
	
	float d = 1. - length(2.0 * pixel_uv - 1.0);
	d = max(0., d);
	
	COLOR.a = d * 0.5;
}
"

